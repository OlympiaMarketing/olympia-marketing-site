}

.mobile { display:none; }
.breadcrumb span, .breadcrumb a { 
    color: #fff;
    font-size: 18px;
    text-decoration: none;
    letter-spacing: 1px;
}

h1.entry-title, h2.entry-title {
    font-family: "Livvic";
    font-size: 24px;
    line-height: 1.3em !important;
    font-weight: 700;
    line-height: 1.2em;
    color: #010E37;
    padding: 0 !important;
}
h2, h3, h4, h5, h6 { font-family: "Livvic"; }
header.page-header { padding-bottom:20px; }

#main-nav .sub-menu { 
    border: 1px solid #E1E1E1; 
    padding: 10px 0 !important;
    border-radius: 6px;
    box-shadow: 0 10.5px 20px rgb(0 0 0 / 9%);
}
#main-nav .sub-menu:before {
    content: "";
    width: 15px;
    height: 15px;
    background-color: #fff;
    position: absolute;
    top: 0;
    left: 22px;
    transform: rotate(45deg) translatey(-11px);
    z-index: 8;
    border-top: 1px solid #E1E1E1;
    border-left: 1px solid #E1E1E1;
}
#main-nav .sub-menu .sub-menu { left: -216px; }
#main-nav .sub-menu .sub-menu:before { display:none; }

.banner {
    background-image: url(/wp-content/uploads/2024/02/banner3.jpg);
    background-position: 0px -84px;
    background-repeat: no-repeat;
    background-size: cover;
    text-align: center;
    position: relative;
    padding: 100px 30px;
    margin-bottom: 20px;
}
.banner:before {
    content: '';
    background: #383838c2;
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
}
.banner h1 {
    color: #FFFFFF;
    font-size: 70px;
    font-weight: 700;
    line-height: 1.3em;
    text-shadow: 0px 0px 10px rgba(0,0,0,0.3);
    z-index: 9;
    position: relative;
    padding-bottom: 20px;
}
.breadcrumb {
    z-index: 9;
    position: relative;
}



.services-list a {
    text-decoration: none;
    margin-top: 30px;
    display: block;
    width: fit-content;
}

.faq-col .elementor-tab-title {
    border: 1px solid #D8D8D8;
    margin-bottom: 20px !important;
}
.faq-col .elementor-tab-title.elementor-active {
    margin-bottom: 0 !important;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}
.faq-col .elementor-tab-content {
    border: 2px solid #E1E1E1;
    border-top: 0;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
    margin-bottom: 20px !important;
}
.faq-col .elementor-toggle-icon-right {
    margin-top: 3px;
    font-size: 25px;
}

body.error404 main.site-main {
    text-align: center;
    padding: 70px 30px;
}
body.blog header.page-header { display:none; }


.page-header .entry-title { max-width:1250px; }
body.blog article h2.entry-title { margin-top: 0; }
body.single-post main b, 
body.single-post main strong { font-weight:600; }
body.single-post main h2 { font-size: 25px; line-height: 1.3em;}
body.single-post main p { padding-bottom:10px; }


.author-details {
    padding: 30px;
    border: 1px solid #e6e8e9 !important;
    background: #fff;
    margin: 30px 0;
}
.author-avatar img {
    height: 100px !important;
    width: 100px !important;
}
.article-detail a { 
    color: #000 !important;
    text-decoration:none; 
}
article.list {
    background: #f5f5f5;
    padding: 30px;
    margin-bottom: 50px;
    border-radius: 7px;
    box-shadow: 6px 20px 25px -22px rgba(0, 0, 0, 0.5) !important;
    border: 1px solid #e6e8e9 !important;
}
article.list a { color: #000; }
body.search-results article.post { margin-bottom: 50px; }
.left-side { float:left; width:65%; }
.right-side { float:right; width:30%; }
.clear { clear:both; }
.widget-col {
    background: #f5f5f5;
    border-radius: 7px;
    margin-bottom: 36px;
    box-shadow: 6px 20px 25px -22px rgba(0, 0, 0, 0.5) !important;
    border: 1px solid #e6e8e9 !important;
    padding: 30px;
}

.form-submit input[type="submit"] {
    font-size: 16px;
    background-color:#FFBE00;
    padding: 10px 20px;
    border-radius: 50px;
    color: #fff;
    border: 0;
    font-weight: 500;
}
.widget-col input[type="submit"] {
    font-size: 16px;
    background-color:#000;
    padding: 10px 20px;
    border-radius: 50px;
    color: #fff;
    border: 0;
    font-weight: 500;
}
.widget-col input[type="submit"]:hover,
.form-submit input[type="submit"]:hover { background: #000; }

.widget-col ul { color: #000; padding-left:20px; }
.widget-col ul li { margin: 0 0 10px 0; }
.widget-col ul li:last-child { margin-bottom:0; }
.widget-col a {
    color: #000;
    text-decoration: none;
}
.widget-col h3 {
    font-size: 21px;
    line-height: 24px;
    margin: 0 0 20px 0;
}
.widget-col label { display:block; }
.widget-col input[type="search"] { margin-bottom:5px; outline: 0; }
article.list a.more {
    font-size: 16px;
    background-color: #000;
    border-radius: 50px;
    color: #fff !important;
    border: 0;
    font-weight: 500;
    display: inline-block;
    text-align: center;
    padding: 10px 20px;
    margin-top: 10px;
}
article.list a.more:hover {
    opacity: 0.7;
}
article.list img {
    height: 400px;
    width: 100%;
    object-fit: cover;
    margin-bottom: 10px;
}

.mainwrapper {
    padding: 40px 0;
    max-width: 1240px !important;
    width: 90% !important;
}

#comments { padding-top:30px; }
label {
    font-weight: 700;
    padding-bottom: 10px;
    margin-top: 10px;
}
.comments-area a, .page-content a {
