			.animate-img img {
    animation: scale2 3s alternate infinite;
}


@keyframes scale2 {
    from {
        transform: scale(.8);
        -webkit-transform: scale(.8)
    }

    to {
        transform: scale(1);
        -webkit-transform: scale(1)
